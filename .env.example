SECRET_KEY=change-this-to-a-random-secret
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret
SQLALCHEMY_DATABASE_URI=sqlite:///agri.db

# Mail (for email verification / notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Razorpay (payment gateway - test mode keys from razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# OpenWeatherMap (free API key from openweathermap.org)
OPENWEATHER_API_KEY=your-openweather-api-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
